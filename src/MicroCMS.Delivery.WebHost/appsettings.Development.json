{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "MicroCMS": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../MicroCMS.WebHost/microcms_dev.db"
  },
  "MicroCMS": {
    "Database": {
      "Provider": "Sqlite",
      "IsolationMode": "RowLevel"
    },
    "Cache": {
      "Provider": "InMemory"
    },
    "Storage": {
      "Provider": "Filesystem",
      "BasePath": "../MicroCMS.WebHost/local-media"
    },
    "Search": {
      "Provider": "OpenSearch",
      "Endpoint": "http://localhost:9200"
    }
  }
}
