{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",

  "SiteHost": {
    "DeliveryBaseUrl": "http://localhost:5200",

    // Fallback when no Sites[] entry matches the incoming hostname.
    // Remove or set to null to disable fallback (returns 421 instead).
    "DefaultSite": {
      "SiteId": "00000000-0000-0000-0000-000000000000",
      "ApiKey": "mck_replace_me",
      "DefaultLocale": "en"
    },

    "Sites": [
      {
        "Hostname": "localhost",
        "SiteId": "00000000-0000-0000-0000-000000000000",
        "ApiKey": "mck_replace_me",
        "DefaultLocale": "en"
      },
      {
        "Hostname": "site-a.com",
        "SiteId": "00000000-0000-0000-0000-000000000001",
        "ApiKey": "mck_site_a_key",
        "DefaultLocale": "en"
      },
      {
        "Hostname": "site-b.com",
        "SiteId": "00000000-0000-0000-0000-000000000002",
        "ApiKey": "mck_site_b_key",
        "DefaultLocale": "fr"
      }
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "delivery-home": {
        "ClusterId": "delivery",
        "Match": { "Path": "/" },
        "Transforms": [
          { "PathPattern": "/api/delivery/pages/home/render" }
        ]
      },
      "delivery-pages": {
        "ClusterId": "delivery",
        "Match": { "Path": "/{slug}" },
        "Transforms": [
          { "PathPattern": "/api/delivery/pages/{slug}/render" }
        ]
      }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Warning"
      }
    },
    "WriteTo": [{ "Name": "Console" }]
  }
}
