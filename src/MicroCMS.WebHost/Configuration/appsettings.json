{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MicroCMS": {
    "Database": {
      "Provider": "PostgreSql",
      "IsolationMode": "SchemaPerTenant"
    },
    "Cache": {
      "Provider": "Redis",
      "ConnectionString": ""
    },
    "Storage": {
      "Provider": "Filesystem",
      "BasePath": "/data/media"
    },
    "Search": {
      "Provider": "OpenSearch",
      "Endpoint": "http://localhost:9200"
    },
    "Ai": {
      "DefaultProvider": "AzureOpenAI",
      "EnabledFeatures": [],
      "BudgetEnabled": true
    },
    "Plugins": {
      "Directory": "/plugins",
      "EnableSignatureVerification": true
    }
  }
}
